# Never commit a real monday.com token.
# Locally: copy this file to .env and fill in values.
# Netlify: add these under Site configuration -> Environment variables.

MONDAY_API_TOKEN=
MONDAY_API_VERSION=2026-04

# Board IDs are optional during development because the backend can infer boards
# from names like Projects, Quotes, Documents, Invoices, and Payments.
# For production, set them explicitly once discovery confirms the right IDs.
MONDAY_PROJECTS_BOARD_ID=
MONDAY_QUOTES_BOARD_ID=
MONDAY_DOCUMENTS_BOARD_ID=
MONDAY_INVOICES_BOARD_ID=
MONDAY_PAYMENTS_BOARD_ID=

# Column IDs are optional when your monday column titles are obvious.
# Set them explicitly if your board uses custom names.
MONDAY_PROJECT_STATUS_COLUMN=
MONDAY_PROJECT_CATEGORY_COLUMN=
MONDAY_PROJECT_LOCATION_COLUMN=
MONDAY_PROJECT_DUE_DATE_COLUMN=
MONDAY_PROJECT_PROGRESS_COLUMN=

MONDAY_QUOTE_STATUS_COLUMN=
MONDAY_QUOTE_AMOUNT_COLUMN=
MONDAY_QUOTE_VALID_UNTIL_COLUMN=
MONDAY_QUOTE_DESCRIPTION_COLUMN=

MONDAY_DOCUMENT_TYPE_COLUMN=
MONDAY_DOCUMENT_PROJECT_COLUMN=
MONDAY_DOCUMENT_DATE_COLUMN=

MONDAY_INVOICE_STATUS_COLUMN=
MONDAY_INVOICE_AMOUNT_COLUMN=
MONDAY_INVOICE_DUE_DATE_COLUMN=
MONDAY_INVOICE_ISSUED_DATE_COLUMN=
MONDAY_INVOICE_INVOICE_NUMBER_COLUMN=

MONDAY_PAYMENT_DATE_COLUMN=
MONDAY_PAYMENT_INVOICE_COLUMN=
MONDAY_PAYMENT_PROJECT_COLUMN=
MONDAY_PAYMENT_METHOD_COLUMN=
MONDAY_PAYMENT_REFERENCE_COLUMN=
MONDAY_PAYMENT_AMOUNT_COLUMN=
